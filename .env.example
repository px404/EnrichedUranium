# AgentMesh frontend environment variables.
# Copy this file to `.env.local` for local development, and set these values
# in your Vercel project settings for production deployments.

# Base URL of the AgentMesh backend (the protocol HTTP API).
# In local development this is typically http://localhost:3001.
# For deployments, set this to the public backend URL.
VITE_API_URL=http://localhost:3001
